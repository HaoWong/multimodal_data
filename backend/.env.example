# Database - 本地 PostgreSQL
DATABASE_URL=postgresql://postgres:你的密码@localhost:5432/multimodal_rag

# Ollama - 本地配置
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=bge-m3:latest
OLLAMA_CHAT_MODEL=qwen3:0.6b
OLLAMA_VISION_MODEL=qwen3-vl:2b

# Application
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true

# Vector Settings
VECTOR_DIMENSION=1024
TOP_K_RETRIEVAL=5
SIMILARITY_THRESHOLD=0.7
